<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.scrapms.devicebridge.controller.LoginController"
      styleClass="login-container"
      alignment="CENTER"
      spacing="0">
    
    <!-- Header -->
    <VBox styleClass="login-header" alignment="CENTER" spacing="10">
        <padding>
            <Insets top="40" bottom="40"/>
        </padding>
        <Text text="📡" styleClass="login-icon"/>
        <Text text="Scrap MS Device Bridge" styleClass="login-title"/>
        <Text text="Connect weighbridges and cameras" styleClass="login-subtitle"/>
    </VBox>
    
    <!-- Login Form -->
    <VBox styleClass="login-form" spacing="20" maxWidth="400">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <!-- Server URL -->
        <VBox spacing="8">
            <Label text="Server URL" styleClass="form-label"/>
            <TextField fx:id="serverUrlField" 
                      promptText="https://scrapapi.accomation.io"
                      styleClass="form-input"/>
        </VBox>
        
        <!-- Email -->
        <VBox spacing="8">
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" 
                      promptText="Enter your email"
                      styleClass="form-input"/>
        </VBox>
        
        <!-- Password -->
        <VBox spacing="8">
            <Label text="Password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" 
                          promptText="Enter your password"
                          styleClass="form-input"
                          onAction="#handleLogin"/>
        </VBox>
        
        <!-- Remember Me -->
        <CheckBox fx:id="rememberMeCheckbox" 
                 text="Remember me" 
                 styleClass="form-checkbox"/>
        
        <!-- Error Label -->
        <Label fx:id="errorLabel" 
              styleClass="error-label" 
              wrapText="true"
              visible="false"/>
        
        <!-- Login Button -->
        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="loginButton" 
                   text="Login" 
                   styleClass="btn-primary"
                   onAction="#handleLogin"
                   defaultButton="true"
                   maxWidth="Infinity"
                   HBox.hgrow="ALWAYS"/>
            <ProgressIndicator fx:id="progressIndicator" 
                             prefWidth="30" 
                             prefHeight="30"
                             visible="false"/>
        </HBox>
    </VBox>
    
    <!-- Footer -->
    <VBox styleClass="login-footer" alignment="CENTER" spacing="5">
        <padding>
            <Insets top="20" bottom="20"/>
        </padding>
        <Text text="Version 1.0.0" styleClass="footer-text"/>
        <Text text="© 2024 Scrap MS" styleClass="footer-text"/>
    </VBox>
    
</VBox>
